#!/usr/bin/env zsh

# Alias for opening Neovim with minimal configuration
alias nvimm='nvim -u ~/.config/nvim/minimal.lua'

# Search for processes matching any of the provided patterns.
# Usage: psaux pattern1 pattern2 ...
# Example: psaux nvim node
# - Combines all arguments into a single regex pattern separated by '|'.
# - Filters the output of 'ps aux' to show only matching processes.
# - Excludes the 'grep' process itself from the results.
psaux() {
    local IFS="|"
    ps aux | grep -E "$*" | grep -v grep
}
